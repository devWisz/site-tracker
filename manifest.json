{
  "manifest_version": 3,
  "name": "Site Tracker",
  "version": "2.0",
  "description": "Tracking your sites/tabs and making your life easier.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
} 