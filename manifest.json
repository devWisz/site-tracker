{
  "manifest_version": 3,
  "name": "Site Tracker",
  "version": "3.0",
  "description": "Track visits, time spent, and control your browsing.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
} 